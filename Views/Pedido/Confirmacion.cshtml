@model SneackersStore.Models.Pedido
@{
    ViewData["Title"] = "Pedido Confirmado";
}

<div class="confirmacion-page">
    <div class="container">
        <div class="confirmacion-card">
            <div class="confirmacion-header">
                <div class="check-circle">
                    <i class="fas fa-check"></i>
                </div>
                <h1>¡Pedido Confirmado!</h1>
                <p class="pedido-numero">Número de pedido: <strong>@Model.NumeroPedido</strong></p>
                <p>Hemos recibido tu pedido y lo estamos procesando. Recibirás una confirmación en tu email.</p>
            </div>

            <div class="confirmacion-detalle">
                <h3>Resumen del Pedido</h3>
                <div class="pedido-items">
                    @foreach (var item in Model.Items)
                    {
                        <div class="pedido-item">
                            <span>@item.Producto?.Nombre × @item.Cantidad</span>
                            <span>$@item.Subtotal.ToString("N2")</span>
                        </div>
                    }
                </div>
                <hr />
                <div class="pedido-total">
                    <div class="resumen-linea">
                        <span>Subtotal</span><span>$@Model.Subtotal.ToString("N2")</span>
                    </div>
                    <div class="resumen-linea">
                        <span>Envío</span>
                        <span>@(Model.CostoEnvio == 0 ? "GRATIS" : "$" + Model.CostoEnvio.ToString("N2"))</span>
                    </div>
                    <div class="resumen-total">
                        <strong>Total Pagado</strong>
                        <strong>$@Model.Total.ToString("N2")</strong>
                    </div>
                </div>
            </div>

            <div class="confirmacion-envio">
                <h4><i class="fas fa-map-marker-alt"></i> Dirección de Envío</h4>
                <p>@Model.DireccionEnvio</p>
                <p>@Model.Ciudad, @Model.EstadoProvincia @Model.CodigoPostal</p>
                <p>@Model.Pais</p>
            </div>

            <div class="confirmacion-actions">
                <a asp-controller="Pedido" asp-action="MisPedidos" class="btn-primary">
                    <i class="fas fa-box"></i> Ver Mis Pedidos
                </a>
                <a asp-controller="Catalogo" asp-action="Index" class="btn-outline">
                    <i class="fas fa-shopping-bag"></i> Seguir Comprando
                </a>
            </div>
        </div>
    </div>
</div>
