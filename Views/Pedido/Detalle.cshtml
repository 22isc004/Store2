@model SneackersStore.Models.Pedido
@{
    ViewData["Title"] = $"Pedido {Model.NumeroPedido}";
}

<div class="pedido-detalle-page">
    <div class="container">
        <nav class="breadcrumb">
            <a asp-controller="Pedido" asp-action="MisPedidos">Mis Pedidos</a>
            <span>/</span>
            <span>@Model.NumeroPedido</span>
        </nav>

        <div class="pedido-detalle-layout">
            <div class="pedido-detalle-main">
                <div class="pedido-header-card">
                    <h2>Pedido #@Model.NumeroPedido</h2>
                    <div class="pedido-meta">
                        <span>Fecha: @Model.FechaPedido.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="estado-badge estado-@Model.Estado.ToString().ToLower()">@Model.Estado</span>
                    </div>
                </div>

                <div class="pedido-items-card">
                    <h3>Productos</h3>
                    @foreach (var item in Model.Items)
                    {
                        <div class="pedido-item-row">
                            @if (item.Producto?.Imagen != null)
                            {
                                <img src="@item.Producto.Imagen" alt="@item.Producto.Nombre" />
                            }
                            <div class="pedido-item-info">
                                <strong>@item.Producto?.Nombre</strong>
                                @if (!string.IsNullOrEmpty(item.Talla))
                                {
                                    <span>Talla: @item.Talla</span>
                                }
                                @if (!string.IsNullOrEmpty(item.Color))
                                {
                                    <span>Color: @item.Color</span>
                                }
                                <span>Cantidad: @item.Cantidad</span>
                            </div>
                            <div class="pedido-item-precio">
                                <span>$@item.PrecioUnitario.ToString("N2") c/u</span>
                                <strong>$@item.Subtotal.ToString("N2")</strong>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="pedido-detalle-aside">
                <div class="resumen-card">
                    <h3>Resumen</h3>
                    <div class="resumen-linea"><span>Subtotal</span><span>$@Model.Subtotal.ToString("N2")</span></div>
                    <div class="resumen-linea">
                        <span>Envío</span>
                        <span>@(Model.CostoEnvio == 0 ? "GRATIS" : "$" + Model.CostoEnvio.ToString("N2"))</span>
                    </div>
                    <hr />
                    <div class="resumen-total">
                        <strong>Total</strong>
                        <strong>$@Model.Total.ToString("N2")</strong>
                    </div>
                </div>

                <div class="envio-card">
                    <h3><i class="fas fa-map-marker-alt"></i> Envío a</h3>
                    <p>@Model.DireccionEnvio</p>
                    <p>@Model.Ciudad @Model.CodigoPostal</p>
                    @if (!string.IsNullOrEmpty(Model.Notas))
                    {
                        <p><em>Nota: @Model.Notas</em></p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
