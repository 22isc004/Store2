@model SneackersStore.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="checkout-page">
    <div class="container">
        <h1 class="page-title"><i class="fas fa-lock"></i> Finalizar Compra</h1>

        <div class="checkout-layout">
            <!-- Formulario de envío -->
            <div class="checkout-form">
                <form asp-action="Checkout" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-section">
                        <h3><i class="fas fa-user"></i> Datos de Contacto</h3>
                        <div class="form-grid-2">
                            <div class="form-group">
                                <label asp-for="Nombre"></label>
                                <input asp-for="Nombre" class="form-control" placeholder="Tu nombre" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Apellido"></label>
                                <input asp-for="Apellido" class="form-control" placeholder="Tu apellido" />
                                <span asp-validation-for="Apellido" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="form-grid-2">
                            <div class="form-group">
                                <label asp-for="Email"></label>
                                <input asp-for="Email" class="form-control" type="email" placeholder="tu@email.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Telefono"></label>
                                <input asp-for="Telefono" class="form-control" placeholder="+52 55 0000 0000" />
                                <span asp-validation-for="Telefono" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3><i class="fas fa-map-marker-alt"></i> Dirección de Envío</h3>
                        <div class="form-group">
                            <label asp-for="Direccion"></label>
                            <input asp-for="Direccion" class="form-control" placeholder="Calle, número, colonia" />
                            <span asp-validation-for="Direccion" class="text-danger"></span>
                        </div>
                        <div class="form-grid-2">
                            <div class="form-group">
                                <label asp-for="Ciudad"></label>
                                <input asp-for="Ciudad" class="form-control" placeholder="Ciudad" />
                                <span asp-validation-for="Ciudad" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Estado"></label>
                                <input asp-for="Estado" class="form-control" placeholder="Estado o provincia" />
                            </div>
                        </div>
                        <div class="form-group form-half">
                            <label asp-for="CodigoPostal"></label>
                            <input asp-for="CodigoPostal" class="form-control" placeholder="CP" />
                        </div>
                    </div>

                    <div class="form-section">
                        <h3><i class="fas fa-comment"></i> Notas del Pedido</h3>
                        <div class="form-group">
                            <textarea asp-for="Notas" class="form-control" rows="3"
                                      placeholder="Instrucciones especiales para tu pedido (opcional)"></textarea>
                        </div>
                    </div>

                    <button type="submit" class="btn-primary btn-block btn-lg">
                        <i class="fas fa-check"></i> Confirmar Pedido
                    </button>
                </form>
            </div>

            <!-- Resumen del pedido -->
            <div class="checkout-resumen">
                <h3>Tu Pedido</h3>

                <div class="checkout-items">
                    @foreach (var item in Model.Items)
                    {
                        <div class="checkout-item">
                            <img src="@(item.Imagen ?? "/img/no-image.jpg")" alt="@item.Nombre" />
                            <div class="checkout-item-info">
                                <span>@item.Nombre</span>
                                @if (!string.IsNullOrEmpty(item.Talla))
                                {
                                    <small>Talla: @item.Talla</small>
                                }
                                <span>×@item.Cantidad</span>
                            </div>
                            <span class="checkout-item-precio">$@item.Subtotal.ToString("N2")</span>
                        </div>
                    }
                </div>

                <div class="resumen-lineas">
                    <div class="resumen-linea">
                        <span>Subtotal</span>
                        <span>$@Model.Subtotal.ToString("N2")</span>
                    </div>
                    <div class="resumen-linea">
                        <span>Envío</span>
                        <span>@(Model.CostoEnvio == 0 ? "GRATIS" : "$" + Model.CostoEnvio.ToString("N2"))</span>
                    </div>
                    <hr />
                    <div class="resumen-total">
                        <strong>Total</strong>
                        <strong>$@Model.Total.ToString("N2")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
