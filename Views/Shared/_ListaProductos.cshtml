@model SneackersStore.Models.ViewModels.ProductoFiltroViewModel

@if (!Model.Productos.Any())
{
    <div class="no-productos">
        <i class="fas fa-search"></i>
        <h3>No se encontraron productos</h3>
        <p>Intenta con otros filtros o términos de búsqueda</p>
    </div>
}
else
{
    <div class="productos-info">
        <span>@Model.TotalProductos producto@(Model.TotalProductos != 1 ? "s" : "") encontrado@(Model.TotalProductos != 1 ? "s" : "")</span>
    </div>

    <div class="productos-grid">
        @foreach (var producto in Model.Productos)
        {
            <div class="producto-card">
                <a asp-controller="Catalogo" asp-action="Detalle" asp-route-id="@producto.Id" class="producto-img-link">
                    <img src="@(producto.Imagen ?? "/img/no-image.jpg")" alt="@producto.Nombre" loading="lazy" />
                    @if (producto.PorcentajeDescuento > 0)
                    {
                        <span class="badge-sale">-@producto.PorcentajeDescuento%</span>
                    }
                    @if (producto.EsNuevo && !producto.PrecioOferta.HasValue)
                    {
                        <span class="badge-nuevo">NUEVO</span>
                    }
                    <div class="producto-overlay">
                        <button class="btn-add-cart"
                                data-id="@producto.Id"
                                data-nombre="@producto.Nombre"
                                data-precio="@producto.PrecioEfectivo">
                            <i class="fas fa-shopping-bag"></i> Agregar
                        </button>
                    </div>
                </a>
                <div class="producto-info">
                    @if (!string.IsNullOrEmpty(producto.Marca))
                    {
                        <span class="producto-marca">@producto.Marca</span>
                    }
                    <h3 class="producto-nombre">
                        <a asp-controller="Catalogo" asp-action="Detalle" asp-route-id="@producto.Id">
                            @producto.Nombre
                        </a>
                    </h3>
                    <div class="producto-precios">
                        @if (producto.PrecioOferta.HasValue)
                        {
                            <span class="precio-oferta">$@producto.PrecioOferta.Value.ToString("N2")</span>
                            <span class="precio-original">$@producto.Precio.ToString("N2")</span>
                        }
                        else
                        {
                            <span class="precio-normal">$@producto.Precio.ToString("N2")</span>
                        }
                    </div>
                    @if (producto.Stock == 0)
                    {
                        <span class="sin-stock">Sin stock</span>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Paginación -->
    @if (Model.TotalPaginas > 1)
    {
        <div class="paginacion">
            @for (int i = 1; i <= Model.TotalPaginas; i++)
            {
                <a class="pag-btn @(i == Model.PaginaActual ? "active" : "")"
                   asp-controller="Catalogo" asp-action="Index"
                   asp-route-pagina="@i"
                   asp-route-categoriaId="@Model.CategoriaId"
                   asp-route-busqueda="@Model.Busqueda"
                   asp-route-precioMin="@Model.PrecioMin"
                   asp-route-precioMax="@Model.PrecioMax"
                   asp-route-marca="@Model.Marca"
                   asp-route-ordenar="@Model.Ordenar">@i</a>
            }
        </div>
    }
}
