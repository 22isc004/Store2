@model SneackersStore.Models.ViewModels.PerfilViewModel
@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="perfil-page">
    <div class="container">
        <h1 class="page-title"><i class="fas fa-user-circle"></i> Mi Perfil</h1>

        <div class="perfil-layout">
            <!-- Formulario de datos personales -->
            <div class="perfil-form-card">
                <h3>Datos Personales</h3>

                <form asp-action="Perfil" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>

                    <div class="form-grid-2">
                        <div class="form-group">
                            <label asp-for="Nombre"></label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Apellido"></label>
                            <input asp-for="Apellido" class="form-control" />
                            <span asp-validation-for="Apellido" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" class="form-control" disabled />
                    </div>

                    <div class="form-group">
                        <label asp-for="Telefono"></label>
                        <input asp-for="Telefono" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Direccion"></label>
                        <input asp-for="Direccion" class="form-control" placeholder="Calle, número, colonia" />
                    </div>

                    <div class="form-grid-2">
                        <div class="form-group">
                            <label asp-for="Ciudad"></label>
                            <input asp-for="Ciudad" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="CodigoPostal"></label>
                            <input asp-for="CodigoPostal" class="form-control" />
                        </div>
                    </div>

                    <button type="submit" class="btn-primary">
                        <i class="fas fa-save"></i> Guardar Cambios
                    </button>
                </form>
            </div>

            <!-- Pedidos recientes -->
            <div class="perfil-pedidos-card">
                <h3>Pedidos Recientes</h3>

                @if (!Model.PedidosRecientes.Any())
                {
                    <p class="text-muted">No tienes pedidos aún.</p>
                }
                else
                {
                    @foreach (var pedido in Model.PedidosRecientes)
                    {
                        <div class="mini-pedido">
                            <div>
                                <strong>#@pedido.NumeroPedido</strong>
                                <span class="text-muted">@pedido.FechaPedido.ToLocalTime().ToString("dd/MM/yyyy")</span>
                            </div>
                            <div>
                                <span class="estado-badge estado-@pedido.Estado.ToString().ToLower()">@pedido.Estado</span>
                                <strong>$@pedido.Total.ToString("N2")</strong>
                            </div>
                        </div>
                    }
                }

                <a asp-controller="Pedido" asp-action="MisPedidos" class="btn-outline btn-sm mt-3">
                    Ver todos mis pedidos
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
