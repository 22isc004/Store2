@model SneackersStore.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Bienvenido de vuelta</h1>
            <p>Inicia sesión en tu cuenta Sneackers Store</p>
        </div>

        <form asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>

            <div class="form-group">
                <label asp-for="Email">
                    <i class="fas fa-envelope"></i> Email
                </label>
                <input asp-for="Email" class="form-control" placeholder="tu@email.com" autofocus />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">
                    <i class="fas fa-lock"></i> Contraseña
                </label>
                <div class="input-password">
                    <input asp-for="Password" class="form-control" id="passwordInput" placeholder="Tu contraseña" />
                    <button type="button" class="toggle-password" onclick="togglePassword()">
                        <i class="fas fa-eye" id="eyeIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group form-check">
                <input asp-for="RecordarMe" class="form-check-input" type="checkbox" />
                <label asp-for="RecordarMe" class="form-check-label">Recordarme</label>
            </div>

            <button type="submit" class="btn-primary btn-block btn-lg">
                <i class="fas fa-sign-in-alt"></i> Iniciar Sesión
            </button>
        </form>

        <div class="auth-footer">
            <p>¿No tienes cuenta?
                <a asp-controller="Cuenta" asp-action="Registro">Regístrate gratis</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
<script>
    function togglePassword() {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }
</script>
}
