@model SneackersStore.Models.Producto
@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="admin-form-page">
    <nav class="admin-breadcrumb">
        <a asp-area="Admin" asp-controller="Productos" asp-action="Index">Productos</a>
        <span>/</span>
        <span>Nuevo Producto</span>
    </nav>

    <div class="admin-card">
        <form asp-action="Crear" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>

            <div class="form-section-admin">
                <h4>Información Básica</h4>
                <div class="form-grid-2">
                    <div class="form-group">
                        <label asp-for="Nombre"></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Nombre del producto" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="CategoriaId"></label>
                        <select asp-for="CategoriaId" asp-items="ViewBag.Categorias" class="form-control">
                            <option value="">-- Selecciona categoría --</option>
                        </select>
                        <span asp-validation-for="CategoriaId" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-grid-2">
                    <div class="form-group">
                        <label asp-for="Marca"></label>
                        <input asp-for="Marca" class="form-control" placeholder="Nike, Adidas, etc." />
                    </div>
                    <div class="form-group">
                        <label asp-for="Modelo"></label>
                        <input asp-for="Modelo" class="form-control" placeholder="Air Force 1, etc." />
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Descripcion"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Descripción detallada del producto"></textarea>
                </div>
            </div>

            <div class="form-section-admin">
                <h4>Precio y Stock</h4>
                <div class="form-grid-3">
                    <div class="form-group">
                        <label asp-for="Precio"></label>
                        <div class="input-prefix">
                            <span>$</span>
                            <input asp-for="Precio" class="form-control" type="number" step="0.01" min="0.01" />
                        </div>
                        <span asp-validation-for="Precio" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="PrecioOferta"></label>
                        <div class="input-prefix">
                            <span>$</span>
                            <input asp-for="PrecioOferta" class="form-control" type="number" step="0.01" min="0" placeholder="Opcional" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="Stock"></label>
                        <input asp-for="Stock" class="form-control" type="number" min="0" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-section-admin">
                <h4>Variantes</h4>
                <div class="form-grid-2">
                    <div class="form-group">
                        <label asp-for="Tallas"></label>
                        <input asp-for="Tallas" class="form-control" placeholder="Ej: 38,39,40,41,42" />
                        <small class="form-text">Separar tallas con comas</small>
                    </div>
                    <div class="form-group">
                        <label asp-for="Colores"></label>
                        <input asp-for="Colores" class="form-control" placeholder="Ej: Negro,Blanco,Rojo" />
                        <small class="form-text">Separar colores con comas</small>
                    </div>
                </div>
            </div>

            <div class="form-section-admin">
                <h4>Imagen</h4>
                <div class="form-group">
                    <label for="imagenFile">Subir Imagen</label>
                    <input type="file" name="imagenFile" id="imagenFile" class="form-control"
                           accept="image/*" onchange="previewImagen(this)" />
                    <div id="imagenPreview" class="imagen-preview" style="display:none">
                        <img id="previewImg" src="" alt="Preview" />
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Imagen">O URL de la imagen</label>
                    <input asp-for="Imagen" class="form-control" placeholder="https://..." />
                </div>
            </div>

            <div class="form-section-admin">
                <h4>Opciones</h4>
                <div class="form-checks-row">
                    <label class="form-check-label">
                        <input asp-for="Activo" type="checkbox" /> Producto Activo
                    </label>
                    <label class="form-check-label">
                        <input asp-for="Destacado" type="checkbox" /> Destacado en el inicio
                    </label>
                    <label class="form-check-label">
                        <input asp-for="EsNuevo" type="checkbox" /> Marcar como Nuevo
                    </label>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary btn-lg">
                    <i class="fas fa-save"></i> Guardar Producto
                </button>
                <a asp-area="Admin" asp-controller="Productos" asp-action="Index" class="btn-outline btn-lg">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
<script>
    function previewImagen(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('previewImg').src = e.target.result;
                document.getElementById('imagenPreview').style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
}
